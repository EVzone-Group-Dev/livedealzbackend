# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=3000
APP_NAME=LiveDeals API

# ============================================
# Database (Prisma + PostgreSQL)
# ============================================
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# ============================================
# Kafka Configuration (for events)
# ============================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=livedeals-api

# ============================================
# LiveKit Configuration (for video streaming)
# ============================================
LIVEKIT_URL=https://your-livekit-server.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ============================================
# AWS S3 (for media storage)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=livedeals-media

# ============================================
# Email/SMTP Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@livedeals.com

# ============================================
# External API Keys
# ============================================
# Add any external service API keys here
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=

# ============================================
# Feature Flags
# ============================================
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=https://your-frontend-domain.com
CORS_CREDENTIALS=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
